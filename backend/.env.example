# -----------------------------------------------------------------------
# Is There a Dishwasher? — backend environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# -----------------------------------------------------------------------

# ── Stage 2: Vision API ─────────────────────────────────────────────────
# Required for photo-based dishwasher detection.
# Without VISION_API_KEY the backend falls back to text-only analysis.

# OpenAI (default)
VISION_API_KEY=sk-...
VISION_API_ENDPOINT=https://api.openai.com/v1/chat/completions
VISION_MODEL=gpt-4o-mini

# --- OR: Azure OpenAI ---
# VISION_API_KEY=<azure-key>
# VISION_API_ENDPOINT=https://my-resource.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2024-02-01
# VISION_MODEL=gpt-4o

# --- OR: Self-hosted Ollama (no key needed) ---
# VISION_API_KEY=
# VISION_API_ENDPOINT=http://localhost:11434/v1/chat/completions
# VISION_MODEL=llava

# ── Optional tuning ─────────────────────────────────────────────────────

# Maximum number of listing photos to analyse per request (default: 10).
# Lower this to reduce cost; raise it for higher recall on large galleries.
# VISION_MAX_IMAGES=10

# Per-call timeout in seconds for the vision API (default: 30).
# VISION_TIMEOUT_SECONDS=30
